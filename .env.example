# ============================================================================
#  Optimus Payment Gateway — configuration.  Copy to `.env` and edit.
#  Only OPG_GATEWAY_XPUB (or OPG_SHARED_RECEIVE_ADDRESS) is strictly required.
# ============================================================================

# --- core ---
OPG_DB_PATH=optimus_gateway.db
OPG_HOST=0.0.0.0
OPG_PORT=8000
OPG_BASE_URL=http://localhost:8000          # for testing; set to your real https URL in production
OPG_QUOTE_CURRENCY=USD

# --- which networks to accept (comma list) ---
# EVM: usdt_bep20 | usdt_polygon | usdt_arbitrum | usdt_optimism | usdt_base | usdt_erc20 | usdt_avalanche
# TON: usdt_ton
OPG_ENABLED_METHODS=usdt_bep20,usdt_polygon
OPG_ACCEPT_USDC=true

# --- RECEIVING wallet ---------------------------------------------------------
# RECOMMENDED: per-order addresses from a WATCH-ONLY account xpub (m/44'/60'/0'/0).
# Keep the seed OFFLINE. See docs/XPUB_GUIDE.md to get this from any wallet.
OPG_GATEWAY_XPUB=

# ALTERNATIVE (simpler, less private): one shared address, orders matched by a
# unique cents amount. Leave OPG_GATEWAY_XPUB empty to use this.
OPG_SHARED_RECEIVE_ADDRESS=

# --- AUTO-SWEEP (optional) ----------------------------------------------------
# Forward incoming funds to your COLD main wallet automatically. Requires the
# dedicated hot-wallet xprv (create with `python run.py newwallet`). The xprv is
# read from this locked file — never commit it, never put it in an env var.
OPG_SWEEP_KEY_PATH=private/gateway_sweep/account.xprv
OPG_SWEEP_DESTINATION=                       # your cold main wallet (0x...)
OPG_AUTO_SWEEP=false

# --- watcher tuning ---
# Global fallback confirmation depth. Each chain also has a tuned per-chain default
# (BSC 12 / ETH 6 / Polygon 20 / Arbitrum·Optimism·Base 5 / Avalanche 4); override a
# single chain from the DB setting confirmations_<method> (e.g. confirmations_usdt_erc20).
OPG_MIN_CONFIRMATIONS=6
OPG_RESERVATION_TTL_MINUTES=40
OPG_WATCH_POLL_SECONDS=20

# --- TON (only if usdt_ton is enabled) ---
OPG_TON_ADDRESS=                             # your TON wallet (UQ.../EQ...)
OPG_TONCENTER_API_KEY=

# --- Binance verification (optional; personal READ-ONLY API key) — see docs/BINANCE.md ---
OPG_BINANCE_ENABLED=false
OPG_BINANCE_API_KEY=
OPG_BINANCE_API_SECRET=
OPG_BINANCE_AMOUNT_TOLERANCE=0.50
OPG_BINANCE_PAY_ID=              # your Binance Pay ID (receiver) — verifies the payment landed on YOU
OPG_BINANCE_MIN_AGE_MINUTES=0    # reject Binance Pay payments younger than N minutes (anti-race)
OPG_BINANCE_BASE_URL=https://api.binance.com

# --- merchant API auth + webhook signing ---
# LEAVE BLANK for local testing: while empty, create-order is accepted ONLY from
# localhost (safe default). Before exposing the API publicly, set BOTH — then every
# create-order call must include `api_key` + an HMAC-SHA256 `signature`, and webhooks
# are signed with the secret.
OPG_MERCHANT_API_KEY=
OPG_MERCHANT_API_SECRET=
# Only set this if you deliberately want a KEYLESS API reachable from non-local hosts
# (e.g. behind your own trusted gateway/VPN). Default false = remote keyless calls 403.
OPG_ALLOW_UNAUTHENTICATED=false
# SSRF guard: merchant notify_url is fetched by this server, so callbacks to private/
# loopback hosts (localhost, 10.x, 169.254.169.254 metadata, …) are refused. Set true
# ONLY for local webhook testing.
OPG_ALLOW_PRIVATE_WEBHOOKS=false

# --- admin dashboard (optional; empty password disables it) ---
OPG_ADMIN_USER=admin
OPG_ADMIN_PASSWORD=
OPG_ADMIN_PORT=8001
OPG_ADMIN_SECRET_KEY=                         # Flask session key; set a random value in production

# --- Litecoin rail (optional; configured SEPARATELY from the EVM wizard) — see docs/LITECOIN.md ---
# LTC is a tested adapter: watch-only BIP84 derivation + BIP143 signer + USD-value crediting.
# Deposits credit at USD VALUE, so a live LTC/USD rate is REQUIRED (else they credit $0.00).
OPG_LTC_ENABLED=false
OPG_LTC_XPUB=                                  # watch-only BIP84 zpub/xpub for LTC receiving addresses
OPG_LTC_USD_RATE=                              # static LTC/USD (or wire a live feed via set_ltc_rate_provider)
OPG_LTC_AUTO_SWEEP=false
OPG_LTC_SWEEP_DESTINATION=                     # your LTC cold address (ltc1...)
OPG_LTC_SWEEP_KEY_PATH=private/gateway_sweep/ltc_account.xprv   # 0600 file; never commit / never env
OPG_LTC_SWEEP_XPRV=                            # alternative to the key file (discouraged)
OPG_LTC_SWEEP_MIN_USD=0                        # only consolidate once this much USD has accumulated

# --- advanced tuning (sane defaults; only touch if you know why) ---
OPG_RESCAN_OVERLAP=24                          # blocks re-scanned each cycle (crash-safety overlap)
OPG_MAX_CATCHUP_BLOCKS=1500                    # cap blocks scanned per cycle when catching up
OPG_AMOUNT_COOLDOWN_MINUTES=1440               # shared-address / late-payment window (24h)
OPG_POOL_REISSUE_FLOOR_MINUTES=60              # min idle before an UNPAID pool address is reissued
OPG_SWEEP_POLL_SECONDS=120                     # how often auto-sweep runs
OPG_WRONGNET_POLL_SECONDS=300                  # how often wrong-network recovery runs
OPG_GAS_ALERT_THRESHOLD=0.005                  # warn when a gas tank drops below this (native coin)
OPG_WEBHOOK_MAX_RETRIES=8                      # retries for a failing merchant webhook
OPG_WEBHOOK_TIMEOUT=10                         # seconds per webhook delivery attempt
OPG_LOG_LEVEL=INFO
